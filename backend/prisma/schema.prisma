generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  relatos Relato[]
}

model Relato {
  id        String   @id @default(uuid())

  data      String
  hora      String
  texto     String
  tags      String[]
  emoji     String

  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])
}