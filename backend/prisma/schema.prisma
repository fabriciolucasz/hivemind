generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  password             String
  resetToken           String?   @map("reset_token")
  resetTokenExpiresAt  DateTime? @map("reset_token_expires_at") @db.Timestamptz(3)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  profile Profile?

  @@map("users")
}

model Profile {
  id        String   @id @default(uuid())
  age       Int?
  interests String[]

  reminderActive Boolean @default(false) @map("reminder_active")
  reminderTime   String?  @default("18:00") @map("reminder_time")

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  dailyLogs       DailyLog[]
  academicRecords AcademicRecord[]
  vocationalTests VocationalTest[]
  events          Event[]
  recommendations Recommendation[]

  @@map("profiles")
}

model DailyLog {
  id    String   @id @default(uuid())
  date  String
  time  String
  text  String
  tags  String[]
  emoji String

  profile   Profile @relation(fields: [profileId], references: [id])
  profileId String  @map("profile_id")

  embedding Unsupported("vector(384)")?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([profileId])
  @@map("daily_logs")
}

model AcademicRecord {
  id                 String  @id @default(uuid())
  activity           String  @default("Atividade")
  academicDiscipline String  @map("academic_discipline")
  score              Float
  maxScore           Float   @default(10) @map("max_score")
  type               String  @default("test")
  notes              String?

  profile   Profile @relation(fields: [profileId], references: [id])
  profileId String  @map("profile_id")

  realizedAt DateTime @default(now()) @map("realized_at") @db.Timestamptz(3)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([profileId])
  @@map("academic_records")
}

model VocationalTest {
  id         String       @id @default(uuid())
  name       String
  result     String
  realizedAt DateTime     @default(now()) @map("realized_at") @db.Timestamptz(3)
  answers    TestAnswer[]

  profile   Profile @relation(fields: [profileId], references: [id])
  profileId String  @map("profile_id")

  @@index([profileId])
  @@map("vocational_tests")
}

model TestAnswer {
  id         String @id @default(uuid())
  questionId String @map("question_id")
  answer     String

  vocationalTest   VocationalTest @relation(fields: [vocationalTestId], references: [id])
  vocationalTestId String         @map("vocational_test_id")

  @@index([vocationalTestId])
  @@map("test_answers")
}

model Event {
  id           String             @id @default(uuid())
  title        String
  description  String?
  date         DateTime?          @db.Timestamptz(3)
  location     String?
  type         String             @default("other")
  isAttending  Boolean            @default(false) @map("is_attending")
  notes        String?
  rating       Int?
  observations ObservationEvent[]

  profile   Profile @relation(fields: [profileId], references: [id])
  profileId String  @map("profile_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([profileId])
  @@map("events")
}

model ObservationEvent {
  id   String @id @default(uuid())
  text String

  event   Event  @relation(fields: [eventId], references: [id])
  eventId String @map("event_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([eventId])
  @@map("observation_events")
}

model Recommendation {
  id      String              @id @default(uuid())
  reason  String
  courses RecommendedCourse[]

  profile   Profile @relation(fields: [profileId], references: [id])
  profileId String  @map("profile_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([profileId])
  @@map("recommendations")
}

model RecommendedCourse {
  id       String @id @default(uuid())
  name     String
  affinity Float?

  recommendation   Recommendation @relation(fields: [recommendationId], references: [id])
  recommendationId String         @map("recommendation_id")

  @@index([recommendationId])
  @@map("recommended_courses")
}
